# ---------------------------------------------------------------------
# DjOpenKB Vault bootstrap secrets
# ---------------------------------------------------------------------
# This file is only for first-time seeding OR intentional secret rotation.
# Do NOT commit vault/bootstrap/djopenkb.env.
#
# First setup:
#   cp vault/bootstrap/djopenkb.env.example vault/bootstrap/djopenkb.env
#   ./vault/bootstrap/generate-secrets.sh
#   nano vault/bootstrap/djopenkb.env
#   sudo docker compose up -d --build
#   remove vault/bootstrap/djopenkb.env after Vault says the secret is created
#
# Updating LDAP/API/SMTP secrets later:
#   edit vault/bootstrap/djopenkb.env with only the values being changed
#   sudo docker compose up -d --force-recreate vault-init
#   sudo docker compose restart web ai-worker notification-worker cleanup-scheduler
#   remove vault/bootstrap/djopenkb.env after confirming the affected service works
#
# Existing Vault values are preserved when the bootstrap file leaves a value blank.
# To rotate a secret, provide its replacement value. This bootstrap workflow does
# not use blank values to erase a currently stored secret.
#
# IMPORTANT:
# - Do not put spaces around "=".
# - Generated secrets should stay unquoted because they are alphanumeric-only.
# - For manual passwords such as LDAP_BIND_PASSWORD:
#     * Prefer an AD service-account password without shell-breaking characters.
#     * If the password contains shell symbols such as $, `, \, !, &, or spaces,
#       wrap the value in single quotes, for example:
#       LDAP_BIND_PASSWORD='P@ssw0rd!abc$123'
#     * Avoid double quotes for passwords containing $, `, or \ because the
#       bootstrap file is read by a Linux shell.
# - For an existing Postgres database, do not change POSTGRES_PASSWORD here
#   unless you also changed the password inside Postgres itself.

DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret-key
# Separate encryption key for recoverable sensitive database fields, such as MFA authenticator secrets.
# Keep this stable. Do not rotate it unless you first re-encrypt existing database values.
DJANGO_FIELD_ENCRYPTION_KEY=replace-with-a-long-random-field-encryption-key
POSTGRES_PASSWORD=replace-with-stable-postgres-password

# OpenKB AI provider key.
# Simple mode: keep using AI_API_KEY as one general fallback key.
# Production mode: prefer the provider-specific key matching OPENKB_AI_MODEL.
# Examples:
# - Gemini model  -> GEMINI_API_KEY
# - OpenAI model  -> OPENAI_API_KEY
# - Claude model  -> ANTHROPIC_API_KEY
AI_API_KEY=replace-with-selected-ai-provider-api-key
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AD LDAP service account password, for example svc_djopenkb@ad.example.com.
# Use no quotes for simple passwords. Use single quotes if the password contains
# shell special characters.
LDAP_BIND_PASSWORD=replace-with-real-ldap-bind-password

# Only used if LDAP_PLACEHOLDER_ENABLED=true.
LDAP_PLACEHOLDER_PASSWORD=replace-with-placeholder-password-or-leave-random
# SMTP relay service account used only to authenticate and submit Knowledge
# Repository review notifications. It must be a dedicated, non-interactive AD
# service account with only the relay permission it needs; never use a domain
# administrator or a personal account.
SMTP_RELAY_USERNAME=svc_djopenkb_mail@ad.example.com
SMTP_RELAY_PASSWORD=replace-with-real-smtp-relay-password

# Set true only for a controlled transition where SMTP intentionally uses the
# exact same password as LDAP_BIND_PASSWORD. When true, it takes precedence over
# SMTP_RELAY_PASSWORD and copies the LDAP bind password inside Vault bootstrap.
# Leave false for the recommended separate SMTP-only account.
SMTP_RELAY_PASSWORD_USE_LDAP_BIND_PASSWORD=false

