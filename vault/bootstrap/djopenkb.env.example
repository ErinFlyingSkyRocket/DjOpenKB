# ---------------------------------------------------------------------
# DjOpenKB Vault bootstrap secrets
# ---------------------------------------------------------------------
# First setup only:
#   cp vault/bootstrap/djopenkb.env.example vault/bootstrap/djopenkb.env
#   edit vault/bootstrap/djopenkb.env with real values
#   docker compose up --build
#   rm vault/bootstrap/djopenkb.env
#
# Do NOT commit vault/bootstrap/djopenkb.env.

DJANGO_SECRET_KEY=replace-with-a-long-random-django-secret-key
POSTGRES_PASSWORD=replace-with-postgres-password

# Gemini/OpenKB AI provider keys
GEMINI_API_KEY=replace-with-gemini-api-key
LLM_API_KEY=replace-with-gemini-api-key-or-llm-key

# AD LDAP service account password, for example the password for svc_djopenkb.
# Your current lab account uses LDAP_BIND_DN in .env.
LDAP_BIND_PASSWORD=replace-with-svc-djopenkb-password

# Only used if LDAP_PLACEHOLDER_ENABLED=true.
LDAP_PLACEHOLDER_PASSWORD=replace-with-placeholder-password-or-leave-random
