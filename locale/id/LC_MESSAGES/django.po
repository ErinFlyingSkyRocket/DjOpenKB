# Added by DjOpenKB locale full cleanup patch
msgid "Discard this pending update draft and revert the editor to the last published version?"
msgstr "Buang draf pembaruan yang menunggu ini dan kembalikan editor ke versi terakhir yang diterbitkan?"

# Added by DjOpenKB locale full cleanup patch
msgid "Discard your saved update draft and reload the last published version?"
msgstr "Buang draf pembaruan tersimpan Anda dan muat ulang versi terakhir yang diterbitkan?"

# Added by DjOpenKB locale full cleanup patch
msgid "Discard your current edits and reload the last published version?"
msgstr "Buang perubahan Anda saat ini dan muat ulang versi terakhir yang diterbitkan?"

# Added by DjOpenKB locale full cleanup patch
msgid "Pending update — This edit is waiting for admin approval. The current published version is still visible to users."
msgstr "Pembaruan menunggu persetujuan — Perubahan ini sedang menunggu persetujuan admin. Versi yang saat ini diterbitkan masih terlihat oleh pengguna."

# Added by DjOpenKB locale full cleanup patch
msgid "Update pending failed — Please review the admin comments, update your changes, and submit again."
msgstr "Pembaruan ditolak — Tinjau komentar admin, perbarui perubahan Anda, lalu kirim lagi."

# Added by DjOpenKB locale full cleanup patch
msgid "Saved update draft — You are currently editing saved changes for this published article. The current published version is still visible until you submit this update for approval."
msgstr "Draf pembaruan tersimpan — Anda sedang mengedit perubahan tersimpan untuk artikel yang sudah diterbitkan ini. Versi yang saat ini diterbitkan tetap terlihat sampai Anda mengirim pembaruan ini untuk persetujuan."

# Added by DjOpenKB locale full cleanup patch
msgid "Editor reverted to the last published version."
msgstr "Editor dikembalikan ke versi terakhir yang diterbitkan."

# Added by DjOpenKB locale full cleanup patch
msgid "Update progress saved. The published version is still visible, and the update has not been submitted for approval yet."
msgstr "Progres pembaruan telah disimpan. Versi yang diterbitkan tetap terlihat, dan pembaruan belum dikirim untuk persetujuan."

