#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Peran tambahan. Dapat membuat/mengedit artikel internal sendiri dan melihat "
"artikel publik/umum."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Peran tambahan. Dapat membuat/mengelola/menghapus artikel internal dan "
"melihat artikel publik/umum."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Peran tambahan. Dapat meninjau artikel/pembaruan internal yang menunggu dan "
"melihat artikel publik/umum."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Peran tambahan. Dapat melihat artikel publik/umum serta menyetujui/menolak "
"artikel dan pembaruan internal yang menunggu."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Peran tambahan. Dapat melihat artikel publik/umum serta membuat/mengedit "
"artikel internal sendiri."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Peran tambahan. Dapat melihat artikel publik/umum dan artikel internal, "
"tetapi tidak dapat membuat atau menyetujui artikel internal."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Peran tambahan. Dapat melihat artikel publik/umum dan artikel internal."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Peran tambahan. Dapat melihat artikel publik/umum, "
"membuat/mengelola/menghapus artikel internal, dan meninjau artikel internal "
"yang menunggu."

