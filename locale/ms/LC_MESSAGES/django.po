#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Peranan tambahan. Boleh mencipta/menyunting artikel dalaman sendiri dan "
"melihat artikel awam/umum."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Peranan tambahan. Boleh mencipta/mengurus/memadam artikel dalaman dan "
"melihat artikel awam/umum."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Peranan tambahan. Boleh menyemak artikel/kemas kini dalaman yang menunggu "
"dan melihat artikel awam/umum."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Peranan tambahan. Boleh melihat artikel awam/umum dan meluluskan/menolak "
"artikel serta kemas kini dalaman yang menunggu."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Peranan tambahan. Boleh melihat artikel awam/umum serta mencipta/menyunting "
"artikel dalaman sendiri."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Peranan tambahan. Boleh melihat artikel awam/umum dan artikel dalaman, "
"tetapi tidak boleh mencipta atau meluluskan artikel dalaman."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Peranan tambahan. Boleh melihat artikel awam/umum serta artikel dalaman."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Peranan tambahan. Boleh melihat artikel awam/umum, mencipta/mengurus/memadam"
" artikel dalaman dan menyemak artikel dalaman yang menunggu."

