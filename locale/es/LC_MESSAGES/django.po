#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Función complementaria. Puede crear/editar sus propios artículos internos y "
"ver artículos públicos/generales."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Función complementaria. Puede crear/gestionar/eliminar artículos internos y "
"ver artículos públicos/generales."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Función complementaria. Puede revisar artículos/actualizaciones internos "
"pendientes y ver artículos públicos/generales."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Función complementaria. Puede ver artículos públicos/generales y "
"aprobar/rechazar artículos y actualizaciones internos pendientes."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Función complementaria. Puede ver artículos públicos/generales y "
"crear/editar sus propios artículos internos."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Función complementaria. Puede ver artículos públicos/generales y artículos "
"internos, pero no puede crear ni aprobar artículos internos."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Función complementaria. Puede ver artículos públicos/generales y artículos "
"internos."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Función complementaria. Puede ver artículos públicos/generales, "
"crear/gestionar/eliminar artículos internos y revisar artículos internos "
"pendientes."

