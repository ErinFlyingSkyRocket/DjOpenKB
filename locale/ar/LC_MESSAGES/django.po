msgid "Authentication and session settings"
msgstr "إعدادات المصادقة والجلسات"

msgid "Domain user passwords are managed in Active Directory."
msgstr "تتم إدارة كلمات مرور مستخدمي النطاق في Active Directory."

msgid "User does not exist."
msgstr "المستخدم غير موجود."

msgid "Marked as pending failed by admin. Please review this article and resubmit it for approval."
msgstr "تم وضعها كفشل في الانتظار بواسطة المسؤول. يُرجى مراجعة هذه المقالة وإعادة إرسالها للموافقة."

msgid "Controls how many pasted/uploaded images each article may contain. Default is 50. Set to 0 to disable article image uploads."
msgstr "يتحكم في عدد الصور الملصقة أو المرفوعة التي يمكن أن تحتوي عليها كل مقالة. القيمة الافتراضية هي 50. اضبطها على 0 لتعطيل رفع صور المقالات."

msgid "Controls the minimum age used by My Profile → Admin tools → Clean stray upload files. Use 0 to show files immediately."
msgstr "يتحكم في الحد الأدنى للعمر المستخدم في ملفي الشخصي ← أدوات المسؤول ← تنظيف الملفات المرفوعة غير المستخدمة. استخدم 0 لعرض الملفات فورًا."

msgid "Controls authentication/MFA logs, general activity logs, admin log display rows, and user session lifetime. Default log retention is 30 days. Admin log tables show 200 rows per page by default. Set session timeout to 0 to expire the session when the browser closes."
msgstr "يتحكم في سجلات المصادقة/المصادقة متعددة العوامل، وسجلات النشاط العامة، وعدد صفوف سجلات المسؤول المعروضة، ومدة جلسة المستخدم. مدة الاحتفاظ الافتراضية بالسجلات هي 30 يومًا. تعرض جداول سجلات المسؤول 200 صف في الصفحة افتراضيًا. اضبط مهلة الجلسة على 0 لإنهاء الجلسة عند إغلاق المتصفح."

msgid "Use this section to reset a user's authenticator setup. A reset generates a new private authenticator secret and forces the user to scan a new QR code at next sign-in."
msgstr "استخدم هذا القسم لإعادة تعيين إعداد تطبيق المصادقة للمستخدم. تؤدي إعادة التعيين إلى إنشاء سر مصادقة خاص جديد وتفرض على المستخدم مسح رمز QR جديد عند تسجيل الدخول التالي."

msgid "Deleted user"
msgstr "مستخدم محذوف"

msgid "Admin/LDAP admin accounts can access Django admin when staff status is enabled."
msgstr "يمكن لحسابات المسؤول/مسؤول LDAP الوصول إلى لوحة إدارة Django عند تمكين حالة الموظف."

msgid "Controls whether the password is managed locally in DjOpenKB or externally by Active Directory."
msgstr "يحدد ما إذا كانت كلمة المرور تُدار محليًا في DjOpenKB أو خارجيًا بواسطة Active Directory."

msgid "Untick this to block the user from accessing the main wiki site."
msgstr "أزل تحديد هذا الخيار لمنع المستخدم من الوصول إلى موقع الويكي الرئيسي."

msgid "Preferred language for the main wiki user interface."
msgstr "اللغة المفضلة لواجهة مستخدم الويكي الرئيسية."

