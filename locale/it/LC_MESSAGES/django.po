#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Ruolo aggiuntivo. Può creare/modificare i propri articoli interni e "
"visualizzare gli articoli pubblici/generali."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Ruolo aggiuntivo. Può creare/gestire/eliminare articoli interni e "
"visualizzare gli articoli pubblici/generali."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Ruolo aggiuntivo. Può esaminare articoli/aggiornamenti interni in attesa e "
"visualizzare gli articoli pubblici/generali."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Ruolo aggiuntivo. Può visualizzare gli articoli pubblici/generali e "
"approvare/rifiutare articoli e aggiornamenti interni in attesa."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Ruolo aggiuntivo. Può visualizzare gli articoli pubblici/generali e "
"creare/modificare i propri articoli interni."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Ruolo aggiuntivo. Può visualizzare gli articoli pubblici/generali e gli "
"articoli interni, ma non può creare né approvare articoli interni."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Ruolo aggiuntivo. Può visualizzare gli articoli pubblici/generali e gli "
"articoli interni."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Ruolo aggiuntivo. Può visualizzare gli articoli pubblici/generali, "
"creare/gestire/eliminare articoli interni ed esaminare articoli interni in "
"attesa."

