# Article image upload limit strings
msgid "Article image upload limit"
msgstr "Makale görseli yükleme sınırı"

msgid "Maximum number of pasted/uploaded images allowed per article, including draft, pending, published, and pending-update versions. Default is 50. Set to 0 to disable article image uploads."
msgstr "Makale başına izin verilen yapıştırılmış veya yüklenmiş görsellerin azami sayısı; taslak, beklemede, yayımlanmış ve güncelleme bekleyen sürümler dahildir. Varsayılan 50’dir. Makale görseli yüklemelerini devre dışı bırakmak için 0 olarak ayarlayın."

msgid "Article image uploads are currently disabled by the administrator."
msgstr "Makale görseli yüklemeleri şu anda yönetici tarafından devre dışı bırakıldı."

msgid "This article has reached the image upload limit of %(limit)s image(s)."
msgstr "Bu makale %(limit)s görsel yükleme sınırına ulaştı."

msgid "This article has %(count)s image(s), but the maximum allowed is %(limit)s image(s). Please remove some images before saving."
msgstr "Bu makalede %(count)s görsel var, ancak izin verilen azami sayı %(limit)s. Kaydetmeden önce bazı görselleri kaldırın."

msgid "Maximum %(limit)s image(s) per article."
msgstr "Makale başına en fazla %(limit)s görsel."

msgid "This article has reached the image upload limit. Please remove an image before uploading another one."
msgstr "Bu makale görsel yükleme sınırına ulaştı. Başka bir görsel yüklemeden önce bir görseli kaldırın."
