#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Aanvullende rol. Kan eigen interne artikelen maken/bewerken en "
"openbare/algemene artikelen bekijken."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Aanvullende rol. Kan interne artikelen maken/beheren/verwijderen en "
"openbare/algemene artikelen bekijken."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Aanvullende rol. Kan interne artikelen/updates in afwachting beoordelen en "
"openbare/algemene artikelen bekijken."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Aanvullende rol. Kan openbare/algemene artikelen bekijken en interne "
"artikelen en updates in afwachting goedkeuren/afwijzen."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Aanvullende rol. Kan openbare/algemene artikelen bekijken en eigen interne "
"artikelen maken/bewerken."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Aanvullende rol. Kan openbare/algemene artikelen en interne artikelen "
"bekijken, maar kan geen interne artikelen maken of goedkeuren."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Aanvullende rol. Kan openbare/algemene artikelen plus interne artikelen "
"bekijken."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Aanvullende rol. Kan openbare/algemene artikelen bekijken, interne artikelen"
" maken/beheren/verwijderen en interne artikelen in afwachting beoordelen."

