# Article image upload limit strings
msgid "Article image upload limit"
msgstr "Лимит загрузки изображений статьи"

msgid "Maximum number of pasted/uploaded images allowed per article, including draft, pending, published, and pending-update versions. Default is 50. Set to 0 to disable article image uploads."
msgstr "Максимальное количество вставленных или загруженных изображений, разрешённое для одной статьи, включая черновики, ожидающие, опубликованные и ожидающие обновления версии. По умолчанию 50. Установите 0, чтобы отключить загрузку изображений статей."

msgid "Article image uploads are currently disabled by the administrator."
msgstr "Загрузка изображений статей в настоящее время отключена администратором."

msgid "This article has reached the image upload limit of %(limit)s image(s)."
msgstr "Эта статья достигла лимита загрузки в %(limit)s изображений."

msgid "This article has %(count)s image(s), but the maximum allowed is %(limit)s image(s). Please remove some images before saving."
msgstr "В этой статье %(count)s изображений, но максимально разрешено %(limit)s изображений. Удалите часть изображений перед сохранением."

msgid "Maximum %(limit)s image(s) per article."
msgstr "Максимум %(limit)s изображений на статью."

msgid "This article has reached the image upload limit. Please remove an image before uploading another one."
msgstr "Эта статья достигла лимита загрузки изображений. Удалите одно изображение перед загрузкой другого."
