#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Supplerende rolle. Kan oprette/redigere egne interne artikler og se "
"offentlige/generelle artikler."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Supplerende rolle. Kan oprette/administrere/slette interne artikler og se "
"offentlige/generelle artikler."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Supplerende rolle. Kan gennemgå afventende interne artikler/opdateringer og "
"se offentlige/generelle artikler."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Supplerende rolle. Kan se offentlige/generelle artikler og godkende/afvise "
"afventende interne artikler og opdateringer."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Supplerende rolle. Kan se offentlige/generelle artikler og oprette/redigere "
"egne interne artikler."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Supplerende rolle. Kan se offentlige/generelle artikler og interne artikler,"
" men kan ikke oprette eller godkende interne artikler."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Supplerende rolle. Kan se offentlige/generelle artikler samt interne "
"artikler."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Supplerende rolle. Kan se offentlige/generelle artikler, "
"oprette/administrere/slette interne artikler og gennemgå afventende interne "
"artikler."

