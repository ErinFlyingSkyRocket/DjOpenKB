#: kb/admin.py:1210
msgid ""
"Add-on role. Can create/edit own internal articles and view public/general "
"articles."
msgstr ""
"Vai trò bổ sung. Có thể tạo/chỉnh sửa các bài viết nội bộ của riêng mình và "
"xem các bài viết công khai/chung."

#: kb/admin.py:1212
msgid ""
"Add-on role. Can create/manage/delete internal articles and view "
"public/general articles."
msgstr ""
"Vai trò bổ sung. Có thể tạo/quản lý/xóa bài viết nội bộ và xem các bài viết "
"công khai/chung."

#: kb/admin.py:1211
msgid ""
"Add-on role. Can review internal pending articles/updates and view "
"public/general articles."
msgstr ""
"Vai trò bổ sung. Có thể xem xét các bài viết/bản cập nhật nội bộ đang chờ và"
" xem các bài viết công khai/chung."

#: kb/admin.py:808
msgid ""
"Add-on role. Can view public/general articles and approve/reject internal "
"pending articles and updates."
msgstr ""
"Vai trò bổ sung. Có thể xem các bài viết công khai/chung và phê duyệt/từ "
"chối các bài viết, bản cập nhật nội bộ đang chờ."

#: kb/admin.py:804
msgid ""
"Add-on role. Can view public/general articles and create/edit their own "
"internal articles."
msgstr ""
"Vai trò bổ sung. Có thể xem các bài viết công khai/chung và tạo/chỉnh sửa "
"các bài viết nội bộ của riêng mình."

#: kb/admin.py:800
msgid ""
"Add-on role. Can view public/general articles and internal articles, but "
"cannot create or approve internal articles."
msgstr ""
"Vai trò bổ sung. Có thể xem các bài viết công khai/chung và bài viết nội bộ "
"nhưng không thể tạo hoặc phê duyệt bài viết nội bộ."

#: kb/admin.py:1209
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr ""
"Vai trò bổ sung. Có thể xem các bài viết công khai/chung và bài viết nội bộ."

#: kb/admin.py:812
msgid ""
"Add-on role. Can view public/general articles, create/manage/delete internal"
" articles, and review internal pending articles."
msgstr ""
"Vai trò bổ sung. Có thể xem các bài viết công khai/chung, tạo/quản lý/xóa "
"bài viết nội bộ và xem xét các bài viết nội bộ đang chờ."

