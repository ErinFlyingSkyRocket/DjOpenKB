msgid "Add-on role. Can view public/general articles and approve/reject internal pending articles and updates."
msgstr "Vai trò bổ sung. Có thể xem các bài viết công khai/chung và phê duyệt/từ chối các bài viết, bản cập nhật nội bộ đang chờ."

#: kb/admin.py:810
msgid "Add-on role. Can view public/general articles and create/edit their own internal articles."
msgstr "Vai trò bổ sung. Có thể xem các bài viết công khai/chung và tạo/chỉnh sửa các bài viết nội bộ của riêng mình."

#: kb/admin.py:806
msgid "Add-on role. Can view public/general articles and internal articles, but cannot create or approve internal articles."
msgstr "Vai trò bổ sung. Có thể xem các bài viết công khai/chung và bài viết nội bộ nhưng không thể tạo hoặc phê duyệt bài viết nội bộ."

#: kb/admin.py:1216
msgid "Add-on role. Can view public/general articles plus internal articles."
msgstr "Vai trò bổ sung. Có thể xem các bài viết công khai/chung và bài viết nội bộ."

#: kb/admin.py:818
msgid "Add-on role. Can view public/general articles, create/manage/delete internal articles, and review internal pending articles."
msgstr "Vai trò bổ sung. Có thể xem các bài viết công khai/chung, tạo/quản lý/xóa bài viết nội bộ và xem xét các bài viết nội bộ đang chờ."

