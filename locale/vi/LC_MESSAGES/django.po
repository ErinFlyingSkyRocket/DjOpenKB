msgid "You have not suggested any articles yet."
msgstr "Bạn chưa đề xuất bài viết nào."

#: kb/views/ai.py:112
msgid "You have reached your OpenKB AI prompt limit for the current 24-hour period. Please try again when your limit resets."
msgstr "Bạn đã đạt giới hạn câu hỏi OpenKB AI trong khoảng thời gian 24 giờ hiện tại. Vui lòng thử lại khi giới hạn được đặt lại."

#: website/templates/admin_orphan_articles.html:277
msgid "You will be asked to confirm before changes are applied. Published articles are queued and recoverable; draft, pending, and failed articles are deleted immediately."
msgstr "Bạn sẽ được yêu cầu xác nhận trước khi áp dụng thay đổi. Bài viết đã xuất bản được đưa vào hàng đợi và có thể khôi phục; bài viết bản nháp, đang chờ và không đạt sẽ bị xóa ngay lập tức."

#: website/templates/admin_orphan_articles.html:277
msgid "You will be asked to confirm before changes are applied. Selected articles will be permanently deleted immediately."
msgstr "Bạn sẽ được yêu cầu xác nhận trước khi áp dụng thay đổi. Các bài viết được chọn sẽ bị xóa vĩnh viễn ngay lập tức."

#: kb/views/mfa.py:594
msgid "Your MFA was reset. Complete authenticator setup now to continue using Knowledge Repository."
msgstr "MFA của bạn đã được đặt lại. Hãy hoàn tất thiết lập trình xác thực ngay để tiếp tục sử dụng Kho tri thức."

#: kb/views/auth.py:37 website/templates/account_disabled.html:29
msgid "Your account is currently disabled and cannot access Knowledge Repository. Please contact an administrator if you believe this is unexpected."
msgstr "Tài khoản của bạn hiện bị vô hiệu hóa và không thể truy cập Kho tri thức. Vui lòng liên hệ quản trị viên nếu bạn cho rằng điều này không mong đợi."

#: kb/admin_security.py:394
msgid "Your admin session expired after inactivity. Verify MFA again to re-enter the admin site."
msgstr "Phiên quản trị của bạn đã hết hạn do không hoạt động. Hãy xác minh MFA lại để vào lại trang quản trị."

#: kb/admin.py:1612
msgid "Your own account was assigned to Disabled User. On the next request, you will be redirected to the account disabled page."
msgstr "Tài khoản của chính bạn đã được gán vai trò Người dùng bị vô hiệu hóa. Trong yêu cầu tiếp theo, bạn sẽ được chuyển đến trang tài khoản bị vô hiệu hóa."

#: website/templates/suggest.html:590 website/templates/suggest_edit.html:811
