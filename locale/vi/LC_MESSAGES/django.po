#: kb/admin.py:635
msgid "Direct user permission. Allows access to article approval workflows such as pending article review, pending update review, approve/reject actions, and review-stage article editing. It does not automatically allow creating new articles, deleting articles, or full Django admin access unless another permission/group grants those."
msgstr "Quyền người dùng trực tiếp. Cho phép truy cập quy trình phê duyệt bài viết như xem xét bài viết đang chờ, xem xét bản cập nhật đang chờ, thao tác phê duyệt/từ chối và chỉnh sửa bài viết trong giai đoạn xem xét. Quyền này không tự động cho phép tạo bài viết mới, xóa bài viết hoặc truy cập toàn bộ Quản trị Django trừ khi được cấp bởi quyền/nhóm khác."

#: kb/admin.py:626
msgid "Direct user permission. Allows the user to create article drafts, submit new articles for approval, and edit/resubmit their own articles or pending updates. It does not allow approving/rejecting other users' articles or using Django admin tools."
msgstr "Quyền người dùng trực tiếp. Cho phép người dùng tạo bản nháp bài viết, gửi bài viết mới để phê duyệt và chỉnh sửa/gửi lại bài viết hoặc bản cập nhật đang chờ của chính mình. Quyền này không cho phép phê duyệt/từ chối bài viết của người dùng khác hoặc sử dụng công cụ quản trị Django."

#: kb/admin.py:616
msgid "Direct user permission. Allows the user to open the main wiki and read published articles after login. It does not allow creating articles, approving articles, or using admin tools. Unticked means no direct user grant; the user may still receive this permission from their group. The Disabled User group overrides direct permission add-ons."
msgstr "Quyền người dùng trực tiếp. Cho phép người dùng mở wiki chính và đọc bài viết đã xuất bản sau khi đăng nhập. Quyền này không cho phép tạo bài viết, phê duyệt bài viết hoặc sử dụng công cụ quản trị. Bỏ chọn nghĩa là không được cấp trực tiếp; người dùng vẫn có thể nhận quyền này từ nhóm của họ. Nhóm Người dùng bị vô hiệu hóa sẽ ghi đè các quyền trực tiếp bổ sung."

#: kb/admin.py:657
msgid "Direct user permission. Allows this user to create and submit internal/private articles."
msgstr "Quyền người dùng trực tiếp. Cho phép người dùng này tạo và gửi bài viết nội bộ/riêng tư."

#: kb/admin.py:644
msgid "Direct user permission. Allows this user to delete articles. Use sparingly; the standard Article Manager and Admin Users groups already grant this."
msgstr "Quyền người dùng trực tiếp. Cho phép người dùng này xóa bài viết. Hãy dùng hạn chế; các nhóm Quản lý bài viết và Người dùng quản trị tiêu chuẩn đã cấp quyền này."

