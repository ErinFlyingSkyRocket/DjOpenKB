msgstr "Uppladdningsgräns för artikelbilder"

msgid "Maximum number of pasted/uploaded images allowed per article, including draft, pending, published, and pending-update versions. Default is 50. Set to 0 to disable article image uploads."
msgstr "Högsta antal inklistrade eller uppladdade bilder som tillåts per artikel, inklusive utkast, väntande, publicerade och väntande uppdateringsversioner. Standard är 50. Sätt till 0 för att inaktivera uppladdning av artikelbilder."

msgid "Article image uploads are currently disabled by the administrator."
msgstr "Uppladdning av artikelbilder är för närvarande inaktiverad av administratören."

msgid "This article has reached the image upload limit of %(limit)s image(s)."
msgstr "Den här artikeln har nått uppladdningsgränsen på %(limit)s bild(er)."

msgid "This article has %(count)s image(s), but the maximum allowed is %(limit)s image(s). Please remove some images before saving."
msgstr "Den här artikeln har %(count)s bild(er), men högst %(limit)s bild(er) tillåts. Ta bort några bilder innan du sparar."

msgid "Maximum %(limit)s image(s) per article."
msgstr "Högst %(limit)s bild(er) per artikel."

msgid "This article has reached the image upload limit. Please remove an image before uploading another one."
msgstr "Den här artikeln har nått uppladdningsgränsen för bilder. Ta bort en bild innan du laddar upp en till."


# Added by DjOpenKB locale full cleanup patch
msgid "Back"
msgstr "Tillbaka"

# Added by DjOpenKB locale full cleanup patch
msgid "Saved update draft"
msgstr "Uppdateringsutkast sparat"

# Added by DjOpenKB locale full cleanup patch
msgid "Revert to last published version"
msgstr "Återgå till senaste publicerade version"

# Added by DjOpenKB locale full cleanup patch
msgid "Save update progress"
msgstr "Spara uppdateringsförlopp"

# Added by DjOpenKB locale full cleanup patch
msgid "Submit update again"
msgstr "Skicka uppdatering igen"

# Added by DjOpenKB locale full cleanup patch
msgid "Discard this pending update draft and revert the editor to the last published version?"
msgstr "Kassera detta väntande uppdateringsutkast och återställ redigeraren till den senaste publicerade versionen?"

# Added by DjOpenKB locale full cleanup patch
msgid "Discard your saved update draft and reload the last published version?"
msgstr "Kassera ditt sparade uppdateringsutkast och ladda om den senaste publicerade versionen?"

# Added by DjOpenKB locale full cleanup patch
msgid "Discard your current edits and reload the last published version?"
msgstr "Kassera dina aktuella ändringar och ladda om den senaste publicerade versionen?"

# Added by DjOpenKB locale full cleanup patch
msgid "Pending update — This edit is waiting for admin approval. The current published version is still visible to users."
msgstr "Väntande uppdatering — Denna redigering väntar på administratörens godkännande. Den nuvarande publicerade versionen är fortfarande synlig för användare."

# Added by DjOpenKB locale full cleanup patch
msgid "Update pending failed — Please review the admin comments, update your changes, and submit again."
msgstr "Uppdateringen godkändes inte — Granska administratörens kommentarer, uppdatera dina ändringar och skicka igen."

# Added by DjOpenKB locale full cleanup patch
msgid "Saved update draft — You are currently editing saved changes for this published article. The current published version is still visible until you submit this update for approval."
msgstr "Uppdateringsutkast sparat — Du redigerar sparade ändringar för denna publicerade artikel. Den nuvarande publicerade versionen förblir synlig tills du skickar denna uppdatering för godkännande."

# Added by DjOpenKB locale full cleanup patch
msgid "Editor reverted to the last published version."
msgstr "Redigeraren återställdes till den senaste publicerade versionen."

# Added by DjOpenKB locale full cleanup patch
msgid "Update progress saved. The published version is still visible, and the update has not been submitted for approval yet."
msgstr "Uppdateringsförloppet sparades. Den publicerade versionen är fortfarande synlig och uppdateringen har ännu inte skickats för godkännande."
