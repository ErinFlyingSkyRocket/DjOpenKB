# ---------------------------------------------------------------------
# DjOpenKB runtime config example
# ---------------------------------------------------------------------
# Copy this file to .env and update the values for your environment.
#
# This file should contain non-secret configuration only.
# Put passwords/API keys in vault/bootstrap/djopenkb.env for first-time Vault seeding.
# After Vault is seeded, delete vault/bootstrap/djopenkb.env from exported/shared copies.

DJANGO_DEBUG=false

# ---------------------------------------------------------------------
# Django host / CSRF settings
# ---------------------------------------------------------------------
# DJANGO_ALLOWED_HOSTS controls which hostnames/IPs Django accepts.
# DJANGO_CSRF_TRUSTED_ORIGINS controls which HTTPS origins can submit forms.
#
# Replace <LINUX_SERVER_IP> with the IP address users type in the browser
# to access DjOpenKB, for example 192.168.81.50.
#
# This is NOT the Windows AD server IP. The AD server IP belongs under LDAP_DC_IP.
#
# Example:
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx,192.168.81.50
# DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost:8080,https://127.0.0.1:8080,https://192.168.81.50:8080
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx,<LINUX_SERVER_IP>
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost:8080,https://127.0.0.1:8080,https://<LINUX_SERVER_IP>:8080

# PostgreSQL used by Docker Compose
POSTGRES_DB=djopenkb
POSTGRES_USER=djopenkb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# OpenKB paths
# Use OPENKB_AI_MODEL for all providers.
OPENKB_BASE_DIR=OpenKB-main
OPENKB_DATA_DIR=openkb-data
OPENKB_AI_PROVIDER=openkb-cli
OPENKB_AI_MODEL=gemini/gemini-2.5-flash
LITELLM_DROP_PARAMS=true

# LDAP / AD optional
# Set LDAP_ENABLED=false if Active Directory login is not required.
LDAP_ENABLED=false
LDAP_PLACEHOLDER_ENABLED=false
LDAP_PLACEHOLDER_AUTO_CREATE_USERS=false

# LDAPS example for Windows Server 2022 AD testing.
# Replace these values with your own AD details if LDAP_ENABLED=true.
LDAP_SERVER_URI=ldaps://WIN-VVCA4BIOSK7.openkb.local:636
LDAP_START_TLS=false
LDAP_CA_CERT_FILE=/etc/ssl/certs/djopenkb-ldap/ad-ca.crt
LDAP_TLS_REQUIRE_CERT=demand
LDAP_ALLOW_INSECURE=false

LDAP_AD_DOMAIN=openkb.local
LDAP_NETBIOS_DOMAIN=OPENKB
LDAP_ALLOWED_EMAIL_DOMAINS=openkb.local

LDAP_USER_SEARCH_BASE=DC=openkb,DC=local
LDAP_USER_FILTER=(|(userPrincipalName=%(user)s)(sAMAccountName=%(user)s)(mail=%(user)s))
LDAP_BIND_DN=svc_djopenkb@openkb.local

# Windows Server 2022 AD Domain Controller IP.
# This is used for Docker hostname resolution when LDAPS uses a DC hostname.
# This is separate from <LINUX_SERVER_IP>.
LDAP_DC_IP=192.168.81.128

# Local fallback only. Keep false for PostgreSQL.
USE_SQLITE=false

# Vault config
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=djopenkb
VAULT_AUTO_UNSEAL_INTERVAL_SECONDS=15
