# ---------------------------------------------------------------------
# DjOpenKB non-secret environment config example
# ---------------------------------------------------------------------
# Copy this file to .env and edit for your deployment.
# Do NOT put secrets here. Put secrets in vault/bootstrap/djopenkb.env once.

DJANGO_DEBUG=false

POSTGRES_DB=djopenkb
POSTGRES_USER=djopenkb
POSTGRES_HOST=db
POSTGRES_PORT=5432

OPENKB_BASE_DIR=OpenKB-main
OPENKB_DATA_DIR=openkb-data
OPENKB_AI_PROVIDER=openkb-cli
OPENKB_GEMINI_MODEL=gemini/gemini-2.5-flash
LITELLM_DROP_PARAMS=true

LDAP_ENABLED=false
LDAP_PLACEHOLDER_ENABLED=false
LDAP_PLACEHOLDER_AUTO_CREATE_USERS=false
# For LDAPS, use the Domain Controller hostname that matches the certificate.
# Example: ldaps://WIN-VVCA4BIOSK7.openkb.local:636
LDAP_SERVER_URI=
LDAP_START_TLS=false
LDAP_CA_CERT_FILE=/etc/ssl/certs/djopenkb-ldap/ad-ca.crt
LDAP_TLS_REQUIRE_CERT=demand
LDAP_ALLOW_INSECURE=false
LDAP_NETWORK_TIMEOUT=5
LDAP_OPERATION_TIMEOUT=5
# Optional Docker hosts mapping for local VMware labs where Docker cannot resolve openkb.local.
LDAP_DC_IP=192.168.81.128
LDAP_AD_DOMAIN=
LDAP_NETBIOS_DOMAIN=
LDAP_ALLOWED_EMAIL_DOMAINS=
LDAP_USER_SEARCH_BASE=
LDAP_USER_FILTER=(|(userPrincipalName=%(user)s)(sAMAccountName=%(user)s)(mail=%(user)s))
LDAP_BIND_DN=

USE_SQLITE=false

VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=djopenkb
VAULT_AUTO_UNSEAL_INTERVAL_SECONDS=15
