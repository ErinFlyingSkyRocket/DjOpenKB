# ---------------------------------------------------------------------
# Knowledge Repository runtime config example
# ---------------------------------------------------------------------
# Copy this file to .env and update the values for your environment.
#
# This file should contain non-secret configuration only.
# Put passwords/API keys in vault/bootstrap/djopenkb.env for first-time Vault seeding.
# After Vault is seeded, delete vault/bootstrap/djopenkb.env from exported/shared copies.

DJANGO_DEBUG=false

# ---------------------------------------------------------------------
# Django host / CSRF settings
# ---------------------------------------------------------------------
# DJANGO_ALLOWED_HOSTS controls which hostnames/IPs Django accepts.
# DJANGO_CSRF_TRUSTED_ORIGINS controls which HTTPS origins can submit forms.
#
# Replace <BROWSER_FACING_PUBLIC_IP> with the browser-facing public IP until a
# DNS name exists, for example 203.0.113.10. Do not include internal Docker
# service names such as web/nginx in production.
#
# This is NOT the Windows AD server IP. The AD server IP belongs under LDAP_DC_IP.
#
# Example when the perimeter firewall presents public HTTPS on 443 and
# translates it to this host's 8080 listener:
# DJANGO_ALLOWED_HOSTS=203.0.113.10
# DJANGO_CSRF_TRUSTED_ORIGINS=https://203.0.113.10
#
# For a direct internal lab URL that users explicitly open on :8080 instead,
# include the actual visible port in the trusted origin: https://<IP>:8080.
#
# After a public DNS name is configured and the perimeter firewall presents
# standard HTTPS on 443, use for example:
# DJANGO_ALLOWED_HOSTS=kb.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://kb.example.com
DJANGO_ALLOWED_HOSTS=<BROWSER_FACING_PUBLIC_IP>
DJANGO_CSRF_TRUSTED_ORIGINS=https://<BROWSER_FACING_PUBLIC_IP>

# Normal authenticated and pending-MFA sessions use a fixed eight-hour expiry.
# The Django Admin Site settings value is the authoritative runtime control;
# this environment value is only the safe startup fallback.
DJANGO_SESSION_TIMEOUT_HOURS=8

# ---------------------------------------------------------------------
# MFA authenticator display name
# ---------------------------------------------------------------------
# This is the name users will see in Microsoft Authenticator, Google
# Authenticator, or similar TOTP apps when they scan the QR code.
MFA_TOTP_ISSUER=Knowledge Repository
# Accept this many adjacent 30-second OTP windows before/after current time.
# Default 2 allows small clock drift. If MFA fails for everyone, check server time first.
MFA_TOTP_VALID_WINDOW=2

# PostgreSQL used by Docker Compose
POSTGRES_DB=djopenkb
POSTGRES_USER=djopenkb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------
# Shared cache / production rate limiting
# ---------------------------------------------------------------------
# Production should use Redis so rate limits and lockouts work across all
# Gunicorn workers. Docker Compose provides the redis service automatically.
REDIS_URL=redis://redis:6379/1
# Keep this false in production. Only set true during emergency recovery if
# Redis is unavailable and you accept weaker per-process limits temporarily.
DJANGO_ALLOW_LOCAL_CACHE_FALLBACK=false

# Password and MFA progressive lockout. Production policy is editable
# in Django Admin > Site settings using inline policy stages.
# This env value is the safe fallback used before migrations/admin settings
# are ready. Format: failed_attempts:block_seconds:repeat_count
# 0 repeat_count means repeat forever. Failed counters reset on successful
# login/MFA verification, admin reset, or after the strike TTL below.
AUTH_LOCKOUT_POLICY_STAGES=10:300:2,5:900:2,3:3600:0
AUTH_LOCKOUT_STRIKE_TTL_SECONDS=604800

# OpenKB paths / AI settings
# Use OPENKB_AI_MODEL for all providers. Examples:
#   gemini/gemini-2.5-flash
#   openai/gpt-5.5
#   anthropic/claude-3-5-sonnet-latest
# Store API keys in Vault, not here. Preferred secret names:
#   GEMINI_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY
# AI_API_KEY still works as a single simple fallback key.
OPENKB_BASE_DIR=OpenKB-main
OPENKB_DATA_DIR=openkb-data
OPENKB_INTERNAL_DATA_DIR=openkb-data-internal
OPENKB_AI_PROVIDER=openkb-cli
OPENKB_AI_MODEL=gemini/gemini-2.5-flash
LITELLM_DROP_PARAMS=true
OPENKB_AI_MAX_PROMPT_CHARS=1000
OPENKB_AI_RATE_LIMIT_MAX_REQUESTS=5
OPENKB_AI_RATE_LIMIT_WINDOW_SECONDS=60
OPENKB_AI_RATE_LIMIT_BLOCK_SECONDS=1800
OPENKB_AI_TIMEOUT_SECONDS=90
OPENKB_AI_CONCURRENCY_LIMIT=2
OPENKB_AI_CONCURRENCY_LOCK_SECONDS=180
# Background AI worker. Compose starts one worker by default; keep this at 1
# on a modest VM, then increase only after observing CPU/RAM and provider limits.
OPENKB_AI_WORKER_CONCURRENCY=1
# Use a separate Redis database for Celery's durable queue, not Django cache DB 1.
OPENKB_AI_CELERY_BROKER_URL=redis://redis:6379/2
OPENKB_AI_CELERY_QUEUE=openkb_ai
# Encrypted temporary prompt/result record lifetime and browser polling interval.
OPENKB_AI_JOB_TTL_SECONDS=1800
OPENKB_AI_JOB_BUSY_RETRIES=12
OPENKB_AI_POLL_INTERVAL_MILLISECONDS=2000

# LDAP / AD optional
# Set LDAP_ENABLED=false if Active Directory login is not required.
LDAP_ENABLED=false
LDAP_PLACEHOLDER_ENABLED=false
LDAP_PLACEHOLDER_AUTO_CREATE_USERS=false

# LDAPS example for Windows Server / Active Directory.
# Replace these values with the real AD details if LDAP_ENABLED=true.
#
# Use the Domain Controller FQDN in LDAP_SERVER_URI, not the IP address,
# because LDAPS certificate validation normally checks the hostname.
LDAP_SERVER_URI=ldaps://<DOMAIN_CONTROLLER_FQDN>:636
LDAP_START_TLS=false
LDAP_CA_CERT_FILE=/etc/ssl/certs/djopenkb-ldap/ad-ca.crt
LDAP_TLS_REQUIRE_CERT=demand
LDAP_ALLOW_INSECURE=false

# AD domain example values. Replace openkb.local/OPENKB with your real AD values.
# Example AD DNS domain / UPN suffix: openkb.local
# Example NetBIOS domain used in OPENKB\username login: OPENKB
# Example public email domain if different: company.com
LDAP_AD_DOMAIN=openkb.local
LDAP_NETBIOS_DOMAIN=OPENKB
LDAP_ALLOWED_EMAIL_DOMAINS=openkb.local,company.com

# For openkb.local, the LDAP search base is DC=openkb,DC=local.
# For example.corp.local, use DC=example,DC=corp,DC=local.
LDAP_USER_SEARCH_BASE=DC=openkb,DC=local
LDAP_USER_FILTER=(|(sAMAccountName=%(user)s)(userPrincipalName=%(user)s)(userPrincipalName=%(user)s@openkb.local)(mail=%(user)s)(mail=%(user)s@openkb.local)(mail=%(user)s@company.com)(userPrincipalName=%(user)s@company.com))

# AD sign-in is deliberately restricted to one approved security group. This
# is required when LDAP_ENABLED=true. Use the full distinguished name (DN), not
# the display name. Nested AD group membership is supported.
LDAP_GROUP_SEARCH_BASE=DC=openkb,DC=local
LDAP_REQUIRED_GROUP_DN=CN=KB-Users,OU=Security Groups,DC=openkb,DC=local

# Service account used only for LDAP bind/search.
# Example: svc_djopenkb@openkb.local
LDAP_BIND_DN=svc_djopenkb@openkb.local

# Optional Windows Server AD Domain Controller hostname/IP mapping.
# Only needed if Docker/Linux cannot resolve the Domain Controller FQDN.
# Example DC FQDN: dc01.openkb.local
# Example short hostname: dc01
# This is separate from <BROWSER_FACING_PUBLIC_IP>.
LDAP_EXTRA_HOSTNAME=dc01.openkb.local
LDAP_EXTRA_SHORT_HOSTNAME=dc01
LDAP_DC_IP=<AD_DC_IP>

# Local fallback only. Keep false for PostgreSQL.
USE_SQLITE=false

# Vault config
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=djopenkb
VAULT_AUTO_UNSEAL_INTERVAL_SECONDS=15
